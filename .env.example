# ================================
# DATABASE
# ================================
DATABASE_URL=postgresql://synthesize:synthesize_password@localhost:5432/synthesizedb
REDIS_URL=redis://localhost:6379/0

# ================================
# AUTHENTICATION & SECURITY
# ================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Admin Portal (separate auth)
ADMIN_JWT_SECRET_KEY=your-admin-jwt-secret-key-change-this
ADMIN_JWT_EXPIRE_MINUTES=480

# ================================
# EXTERNAL SERVICES
# ================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Groq API (for fast LLM inference)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Dodo Payments (Primary Payment Provider)
DODO_API_KEY=your-dodo-api-key
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@synthesize.io
SMTP_FROM_NAME=Synthesize.io

# ================================
# GOOGLE SERVICES
# ================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://synthesize.io
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_PATH=./service-account-key.json

# ================================
# APPLICATION SETTINGS
# ================================
NODE_ENV=development
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# User Web App
WEB_PORT=3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Admin Portal
ADMIN_PORT=3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# API
API_PORT=8000
API_HOST=0.0.0.0
API_WORKERS=4

# ================================
# STORAGE
# ================================
LOCAL_STORAGE_PATH=./data/generated
MAX_UPLOAD_SIZE_MB=100
DATASET_RETENTION_DAYS_STARTER=30
DATASET_RETENTION_DAYS_PROFESSIONAL=90
DATASET_RETENTION_DAYS_BUSINESS=0

# Data Factory Directories
DATA_DIR=./data
DATA_UPLOAD_DIR=./data/uploads
DATA_OUTPUT_DIR=./data/generated
DATA_MODELS_DIR=./data/models

# Data Factory Generation Limits
FAKER_MAX_ROWS=100000
FAKER_MAX_COLUMNS=100
SYNTHCITY_MAX_TRAINING_ROWS=100000
SYNTHCITY_MAX_GENERATION_ROWS=1000000
LLM_MAX_ROWS=1000

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STARTER=100
RATE_LIMIT_PROFESSIONAL=500
RATE_LIMIT_BUSINESS=2000
RATE_LIMIT_ENTERPRISE=10000

# ================================
# CELERY (Background Jobs)
# ================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIMEOUT=900
CELERY_MAX_RETRIES=3

# ================================
# MONITORING & LOGGING
# ================================
LOG_LEVEL=INFO
ENABLE_DEBUG_MODE=true

# Flower (Celery Monitoring)
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# pgAdmin (Database Management)
PGADMIN_EMAIL=admin@synthesize.io
PGADMIN_PASSWORD=admin

# ================================
# DOCKER
# ================================
POSTGRES_USER=synthesize
POSTGRES_PASSWORD=synthesize_password
POSTGRES_DB=synthesizedb
POSTGRES_PORT=5432

REDIS_PORT=6379

# ================================
# FEATURE FLAGS
# ================================
FEATURE_ENABLE_API_ACCESS=true
FEATURE_ENABLE_WEBHOOKS=true
FEATURE_ENABLE_TEAM_WORKSPACE=true
FEATURE_ENABLE_CUSTOM_DATA_TYPES=false

# ================================
# ADMIN PORTAL SECURITY
# ================================
ADMIN_IP_WHITELIST=127.0.0.1,::1
ADMIN_REQUIRE_2FA=true
ADMIN_SESSION_TIMEOUT_MINUTES=240
